{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "automationAccountName": {
      "type": "string",
      "minLength": 6,
      "maxLength": 50,
      "metadata": {
        "description": "Globally unique name for the reusable Automation account."
      }
    },
    "bootstrapUri": {
      "type": "string",
      "defaultValue": "https://raw.githubusercontent.com/seanwest1-flatiron/azure-test/main/runbooks/bootstrap.ps1"
    },
    "runnerVersion": {
      "type": "string",
      "metadata": {
        "description": "Version of the bootstrap runbook deployed by After Party Labs."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Automation/automationAccounts",
      "apiVersion": "2024-10-23",
      "name": "[parameters('automationAccountName')]",
      "location": "[resourceGroup().location]",
      "tags": {
        "after-party-runner": "true",
        "after-party-runner-version": "[parameters('runnerVersion')]"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "disableLocalAuth": true,
        "publicNetworkAccess": true,
        "sku": {
          "name": "Basic"
        }
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/runbooks",
      "apiVersion": "2024-10-23",
      "name": "[format('{0}/{1}', parameters('automationAccountName'), 'AfterPartyBootstrap')]",
      "location": "[resourceGroup().location]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', parameters('automationAccountName'))]"
      ],
      "properties": {
        "description": "Downloads the current After Party payload for every job.",
        "logProgress": false,
        "logVerbose": true,
        "runbookType": "PowerShell",
        "publishContentLink": {
          "uri": "[parameters('bootstrapUri')]"
        }
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceGroup().id, parameters('automationAccountName'), 'after-party-browser-worker')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', parameters('automationAccountName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '5d977122-f97e-4b4d-a52f-6b43003ddb4d')]",
        "principalId": "[reference(resourceId('Microsoft.Automation/automationAccounts', parameters('automationAccountName')), '2024-10-23', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    }
  ],
  "outputs": {
    "automationAccountName": {
      "type": "string",
      "value": "[parameters('automationAccountName')]"
    },
    "managedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Automation/automationAccounts', parameters('automationAccountName')), '2024-10-23', 'Full').identity.principalId]"
    },
    "runbookName": {
      "type": "string",
      "value": "AfterPartyBootstrap"
    }
  }
}
